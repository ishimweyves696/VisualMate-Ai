rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /visuals/{userId}/{allPaths=**} {
      // Allow read/write if the user is authenticated and matches the userId in the path
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    match /profiles/{userId}/{allPaths=**} {
      // Allow read for everyone, write only for the owner
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
